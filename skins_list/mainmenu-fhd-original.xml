<screen name="ServerEagleSat"
    position="center,center"
    size="1800,980"
    title="ServerEagleSat"
    backgroundColor="#000000"
    flags="wfNoBorder">

    <!-- ================= BACKGROUND ================= -->
    <ePixmap position="0,0" size="1800,980" zPosition="0"
        pixmap="/usr/lib/enigma2/python/Plugins/Extensions/ServerEagleSat/icons_list/bg.png"
        transparent="0" alphatest="blend" />

    <!-- ================= LOGO ================= -->
<ePixmap position="30,10" size="150,125" zPosition="8"
    pixmap="/usr/lib/enigma2/python/Plugins/Extensions/ServerEagleSat/icons_list/logo.png"
    transparent="1" alphatest="blend" />

    <!-- ================= BORDERS ================= -->
    <eLabel position="0,0" size="1800,4" zPosition="6" backgroundColor="#E6BE3A" />
    <eLabel position="0,907" size="1800,1" zPosition="6" backgroundColor="#E6BE3A" />
    <eLabel position="0,907" size="4,72" zPosition="6" backgroundColor="#E6BE3A" />
    <eLabel position="1796,0" size="4,126" zPosition="6" backgroundColor="#E6BE3A" />
    <eLabel position="1796,907" size="4,72" zPosition="6" backgroundColor="#E6BE3A" />
    <eLabel position="0,0" size="4,126" zPosition="6" backgroundColor="#E6BE3A" />
    <eLabel position="0,126" size="1800,1" zPosition="7" backgroundColor="#E6BE3A" />
    <eLabel position="0,976" size="1800,4" zPosition="6" backgroundColor="#E6BE3A" />

    <!-- ================= TOP HEADER ================= -->
    <eLabel position="0,0" size="1800,54" zPosition="5" backgroundColor="#000000" />

    <eLabel text="● Welcome to ServerEagleSat – Enjoy the best sharing server for your E2 box."
        position="319,0" size="1444,54"
        zPosition="6"
        font="Bold;32"
        halign="left" valign="center"
        foregroundColor="#E6BE3A"
        transparent="1" />

    <!-- ================= SIDE BARS ================= -->
    <widget name="left_bar"
        position="0,127" size="56,708"
        zPosition="10"
        font="Regular;26"
        halign="center" valign="top"
        foregroundColor="#E6BE3A"
        transparent="1" />

    <widget name="right_bar"
        position="1743,133" size="56,708"
        zPosition="10"
        font="Regular;26"
        halign="center" valign="top"
        foregroundColor="#E6BE3A"
        transparent="1" />

