</widget>

<!-- ================= PANEL ================= -->
<eLabel position="56,127" size="525,41" zPosition="3" backgroundColor="#000000" />
<eLabel text="Main Menus"
    position="56,127" size="525,51"
    zPosition="4"
    font="Bold;32"
    halign="center" valign="center"
    foregroundColor="#E6BE3A"
    backgroundColor="#000000" />

<!-- MENU LIST -->
<widget source="menu"
    render="Listbox"
    position="52,200"
    size="1161,600"
    backgroundColorSelected="#1B3C53"
    listOrientation="vertical"
    itemHeight="60"
    scrollbarMode="showOnDemand"
    transparent="1"
    noWrap="0">

<convert type="TemplatedMultiContent">
{
"template": [

    MultiContentEntryPixmapAlphaTest(
        pos = (10, 5),
        size = (44, 44),
        png = 3
    ),

    MultiContentEntryText(
        pos = (70, 17),
        size = (430, 40),
        font = 0,
        flags = RT_HALIGN_LEFT,
        text = 0
    ),

    MultiContentEntryText(
        pos = (520, 10),
        size = (620, 40),
        font = 1,
        flags = RT_HALIGN_LEFT,
        text = 2
    )

],
"fonts": [
    gFont("Console", 30),
    gFont("Regular", 24)
],
"itemHeight": 60
}
</convert>
</widget>

