<!-- ================= TIME / DATE ================= -->
<widget source="global.CurrentTime" render="Label"
    position="1266,54" size="469,32"
    zPosition="12"
    font="Regular;24"
    halign="center"
    foregroundColor="#E6BE3A"
    transparent="1">
    <convert type="ClockToText">Format %A %d %B</convert>
</widget>

<widget source="global.CurrentTime" render="Label"
    position="1266,86" size="469,32"
    zPosition="12"
    font="Regular;24"
    halign="center"
    foregroundColor="#E6BE3A"
